tubestage(tubetable, vplus, divider, fck, Rk, Vk0) = antiAlias : tube : hpf with {
	antiAlias = fi.lowpass(3, ma.SR / 2.1);
	Rp = 100.0e3;
	VkC = Vk0 * (Rp / Rk);
	lpfk = fi.lowpass(1, fck);
	tube = (+ : -(Vk0) : preAmpTube(tubetable) : +(VkC - vplus)) ~ (*(Rk / Rp) : lpfk) : /(divider);
	hpf = fi.highpass(1, 31.0);
};
