				+manual-chapter("integer", "integer")
					include:markdown language/reference/integer.md

				+manual-chapter("real", "real")
					include:markdown language/reference/real.md

				+manual-chapter("string", "string")
					include:markdown language/reference/string.md

				+manual-chapter("function", "function")
